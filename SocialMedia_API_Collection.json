{
  "info": {
    "name": "Social Media API",
    "description": "A RESTful API collection for the Social Media Backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data.token) {",
                  "    pm.collectionVariables.set(\"jwt_token\", response.data.token);",
                  "    console.log(\"JWT Token captured & saved to variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Posts & Feed",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello world! This is my first ever post.\",\n  \"privacy\": \"PUBLIC\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts"
              ]
            }
          }
        },
        {
          "name": "Get Feed",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/feed?limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "feed"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Interactions",
      "item": [
        {
          "name": "Add Comment to Post",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"I totally agree with this!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/:postId/comments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                ":postId",
                "comments"
              ],
              "variable": [
                {
                  "key": "postId",
                  "value": "<replace_with_post_uuid>"
                }
              ]
            }
          }
        },
        {
          "name": "Reply to Comment",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"You make a fair point as well.\",\n  \"parentId\": \"<replace_with_parent_comment_uuid>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/:postId/comments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                ":postId",
                "comments"
              ],
              "variable": [
                {
                  "key": "postId",
                  "value": "<replace_with_post_uuid>"
                }
              ]
            }
          }
        },
        {
          "name": "Toggle Like on Post",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postId\": \"<replace_with_post_uuid>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/likes/toggle",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "likes",
                "toggle"
              ]
            }
          }
        },
        {
          "name": "Toggle Like on Comment",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"commentId\": \"<replace_with_comment_uuid>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/likes/toggle",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "likes",
                "toggle"
              ]
            }
          }
        },
        {
          "name": "Get Post Likes",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/:postId/likes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                ":postId",
                "likes"
              ],
              "variable": [
                {
                  "key": "postId",
                  "value": "<replace_with_post_uuid>"
                }
              ]
            }
          }
        },
        {
          "name": "Get Comment Likes",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/comments/:commentId/likes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "comments",
                ":commentId",
                "likes"
              ],
              "variable": [
                {
                  "key": "commentId",
                  "value": "<replace_with_comment_uuid>"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
